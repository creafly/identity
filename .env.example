# ===========================================
# Identity Service Configuration
# ===========================================

# Server Configuration
PORT=8080
HOST=0.0.0.0
GIN_MODE=debug  # Use 'release' in production

# ===========================================
# Vault Configuration (recommended for production)
# ===========================================
# When VAULT_ENABLED=true, secrets are loaded from Vault
# with fallback to environment variables.
# For local development without Vault, set VAULT_ENABLED=false
#
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
# VAULT_MOUNT=secret
#
# Vault secrets path: creafly/{ENVIRONMENT}/identity
# Vault secrets:
#   - database_password
#   - jwt_secret
#   - jwt_access_secret (optional)
#   - jwt_refresh_secret (optional)
#   - jwt_temp_secret (optional)
#   - encryption_key
#   - internal_api_key
#   - unleash_api_token

# ===========================================
# Database Configuration
# ===========================================
# Connection parameters (non-sensitive)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=identity
DATABASE_USER=postgres
DATABASE_SSL_MODE=disable

# Password is loaded from Vault (database_password) or env:
DATABASE_PASSWORD=postgres

DATABASE_AUTO_MIGRATE=true

# ===========================================
# JWT Configuration
# ===========================================
# For local development without Vault:
JWT_SECRET=dev-secret-do-not-use-in-production
# In production, jwt_secret is loaded from Vault
JWT_ACCESS_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h

# Separate secrets for different token types (optional, recommended for production)
# If not set, derived from JWT_SECRET (e.g., JWT_SECRET + "-access")
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# JWT_TEMP_SECRET=

# ===========================================
# Service URLs
# ===========================================
NOTIFICATIONS_SERVICE_URL=http://localhost:8081

# ===========================================
# Kafka Configuration
# ===========================================
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=identity-service

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
# Leave empty for development (allows all origins)
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# ===========================================
# Feature Flags (Unleash)
# ===========================================
UNLEASH_ENABLED=false
UNLEASH_URL=http://unleash:4242/api
UNLEASH_APP_NAME=identity
# UNLEASH_API_TOKEN is loaded from Vault

# ===========================================
# Other Settings
# ===========================================
DEFAULT_LOCALE=en-US
LOG_LEVEL=info

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
OTLP_ENDPOINT=localhost:4317
SERVICE_VERSION=1.0.0
ENVIRONMENT=development

# Loki (Centralized Logging)
LOKI_ENABLED=false
LOKI_URL=http://localhost:3100

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# Trusted proxy IPs for X-Forwarded-For parsing (comma-separated)
# Only these IPs are trusted to set X-Forwarded-For header
# Example: TRUSTED_PROXIES=10.0.0.1,10.0.0.2,192.168.1.1
TRUSTED_PROXIES=

# ===========================================
# Internal API Configuration
# ===========================================
# API key for service-to-service authentication
# INTERNAL_API_KEY is loaded from Vault (internal_api_key) or env
INTERNAL_API_KEY=

# Comma-separated list of allowed service names for internal endpoints
INTERNAL_ALLOWED_SERVICES=notifications,agent,subscriptions

# ===========================================
# DEPRECATED
# ===========================================
# DATABASE_URL is no longer used. Use individual components above.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/identity?sslmode=disable
