# ===========================================
# Identity Service Configuration
# ===========================================

# Server Configuration
PORT=8080
HOST=0.0.0.0
GIN_MODE=debug  # Use 'release' in production

# Database (REQUIRED)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/identity?sslmode=disable
DATABASE_AUTO_MIGRATE=true

# JWT Configuration (REQUIRED in production)
# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_ACCESS_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h

# Kafka Configuration
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=identity-service

# Service URLs
NOTIFICATIONS_SERVICE_URL=http://localhost:8081

# CORS Configuration (required in production)
# Comma-separated list of allowed origins
# Leave empty for development (allows all origins)
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# Localization
DEFAULT_LOCALE=en-US

# Logging
LOG_LEVEL=info

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
OTLP_ENDPOINT=localhost:4317
SERVICE_VERSION=1.0.0
ENVIRONMENT=development
